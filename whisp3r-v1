class ProcessManager:
    def __init__(self):
        self.pids: List[subprocess.Popen] = []
        self.lock = threading.Lock()
    def add(self, proc: subprocess.Popen):
        with self.lock:
            self.pids.append(proc)
    def cleanup(self):
        with self.lock:
            for proc in self.pids:
                if proc.poll() is None:
                    try:
                        proc.terminate()
                        proc.wait(timeout=5)
                        logger.info(f"Cleaned up PID {proc.pid}")
                    except Exception as e:
                        logger.warning(f"Failed to clean PID {proc.pid}: {e}")
            self.pids.clear()

proc_mgr = ProcessManager()

