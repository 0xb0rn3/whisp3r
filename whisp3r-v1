def signal_handler(sig, frame):
    logger.warning("Interrupt received. Cleaning up...")
    proc_mgr.cleanup()
    sys.exit(0)

def main():
    signal.signal(signal.SIGINT, signal_handler)
    signal.signal(signal.SIGTERM, signal_handler)
    atexit.register(proc_mgr.cleanup)
    check_root()
    required_tools = ["iw", "nmap", "msfvenom"]
    optional_tools = ["airodump-ng", "aireplay-ng", "aircrack-ng", "bettercap", "arpspoof"]
    for tool in required_tools:
        if not verify_tool(tool):
            logger.warning(f"Missing recommended tool: {tool}")
    parser = argparse.ArgumentParser(description=f"whisp3r v{TOOL_VERSION} - Authorized Offensive Framework | Dev: {DEV_ALIAS}")
    parser.add_argument('--authorized', action='store_true', help='Confirm explicit written authorization')
    parser.add_argument('--dry-run', action='store_true', help='Print commands without execution')
    parser.add_argument('-i', '--interface', help='Network/wireless interface')
    parser.add_argument('--export', choices=['json', 'csv'], help='Export results format')
    parser.add_argument('--mode', choices=['menu', 'wireless', 'network', 'mitm', 'cve', 'payload', 'integrated'], default='menu', help='Direct execution mode')
    parser.add_argument('--target', help='Target IP/BSSID for direct mode')
    parser.add_argument('--cve', help='CVE ID for direct payload generation')
    parser.add_argument('--lhost', help='Callback IP for payload')
    parser.add_argument('--lport', type=int, default=4444, help='Callback port')
    args = parser.parse_args()
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    if args.mode != 'menu':
        if args.mode == 'wireless':
            wireless_recon_workflow(args)
        elif args.mode == 'network':
            network_recon_workflow(args)
        elif args.mode == 'mitm':
            mitm_workflow(args)
        elif args.mode == 'cve':
            vulnerability_analysis_workflow(args)
        elif args.mode == 'payload':
            payload_generation_workflow(args)
        elif args.mode == 'integrated':
            integrated_workflow(args)
    else:
        main_menu(args)
    logger.info("Session complete. All processes cleaned up.")

if __name__ == "__main__":
    main()