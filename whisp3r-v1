def run_cmd(cmd: List[str], timeout: int = 30, dry_run: bool = False, capture: bool = True) -> Optional[str]:
    if dry_run:
        logger.info(f"[DRY RUN] {' '.join(cmd)}")
        return None
    try:
        if capture:
            res = subprocess.run(cmd, check=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True, timeout=timeout)
            return res.stdout.strip()
        else:
            proc = subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            proc_mgr.add(proc)
            return None
    except subprocess.TimeoutExpired:
        logger.error(f"Command timed out: {' '.join(cmd)}")
        return None
    except subprocess.CalledProcessError as e:
        logger.error(f"Command failed ({e.returncode}): {e.stderr.strip()[:200]}")
        return None
    except FileNotFoundError:
        logger.error(f"Command not found: {cmd[0]}")
        return None

def validate_lhost(ip_str: str, allow_external: bool = False) -> bool:
    try:
        ip = ipaddress.ip_address(ip_str)
        if not allow_external and ip.is_global and not ip.is_loopback:
            logger.error(f"LHOST '{ip_str}' is external. Use --allow-external-lhost only with explicit authorization.")
            return False
        return True
    except ValueError:
        logger.error(f"Invalid LHOST format: {ip_str}")
        return False

def detect_wireless_adapters() -> List[WirelessAdapter]:
    adapters = []
    iw_out = run_cmd(["iw", "dev"])
    if not iw_out:
        return adapters
    current_iface = None
    for line in iw_out.splitlines():
        if "Interface" in line:
            current_iface = line.split()[-1]
            if current_iface:
                mac_out = run_cmd(["cat", f"/sys/class/net/{current_iface}/address"], timeout=5)
                adapters.append(WirelessAdapter(name=current_iface, mac=mac_out))
    for adapter in adapters:
        lsusb_out = run_cmd(["lsusb"], timeout=10)
        if lsusb_out and adapter.mac:
            for line in lsusb_out.splitlines():
                if adapter.mac.replace(":", "").lower() in line.replace(":", "").lower():
                    adapter.chipset = line.split(":", 1)[-1].strip()
                    break
        phy_out = run_cmd(["iw", "phy", "phy0", "info"], timeout=10)
        if phy_out and "* monitor" in phy_out:
            adapter.supports_monitor = True
    return adapters

@contextmanager
def monitor_mode_manager(iface: str, dry_run: bool = False):
    original_mode = "managed"
    try:
        mode_out = run_cmd(["iw", "dev", iface, "info"], timeout=10, dry_run=dry_run)
        if mode_out and "type monitor" in mode_out:
            original_mode = "monitor"
            logger.info(f"Interface {iface} already in monitor mode.")
        else:
            if not dry_run:
                logger.info(f"Switching {iface} to monitor mode...")
                run_cmd(["ip", "link", "set", iface, "down"], timeout=10)
                run_cmd(["iw", "dev", iface, "set", "type", "monitor"], timeout=10)
                run_cmd(["ip", "link", "set", iface, "up"], timeout=10)
            else:
                logger.info(f"[DRY RUN] Would switch {iface} to monitor mode.")
        yield
    finally:
        if original_mode == "managed" and not dry_run:
            logger.info(f"Restoring {iface} to managed mode...")
            run_cmd(["ip", "link", "set", iface, "down"], timeout=10)
            run_cmd(["iw", "dev", iface, "set", "type", "managed"], timeout=10)
            run_cmd(["ip", "link", "set", iface, "up"], timeout=10)

def parse_airodump_csv(csv_path: str) -> List[AccessPoint]:
    aps = []
    if not Path(csv_path).exists():
        return aps
    with open(csv_path, 'r', encoding='utf-8', errors='ignore') as f:
        reader = csv.reader(f)
        in_aps = False
        for row in reader:
            if not row or row[0].startswith('#'):
                continue
            if row[0].strip() == "BSSID":
                in_aps = True
                continue
            if in_aps:
                if len(row) >= 14:
                    bssid = row[0].strip()
                    channel = int(row[3].strip()) if row[3].strip().isdigit() else 0
                    enc = row[5].strip()
                    essid = row[13].strip()
                    signal = int(row[8].strip()) if row[8].strip().lstrip('-').isdigit() else -100
                    aps.append(AccessPoint(bssid=bssid, essid=essid, channel=channel, encryption=enc, signal=signal))
                else:
                    break
    return aps

def run_airodump_capture(iface: str, output_prefix: str, duration: int, channel: Optional[int] = None, dry_run: bool = False) -> Optional[str]:
    csv_file = f"{output_prefix}-01.csv"
    pcap_file = f"{output_prefix}-01.cap"
    cmd = ["airodump-ng", "-w", output_prefix, "--output-format", "pcap,csv"]
    if channel:
        cmd.extend(["-c", str(channel)])
    cmd.append(iface)
    if dry_run:
        logger.info(f"[DRY RUN] Would run: {' '.join(cmd)} for {duration}s")
        return pcap_file
    logger.info(f"Starting capture on {iface} for {duration}s...")
    proc = subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    proc_mgr.add(proc)
    start = time.time()
    while time.time() - start < duration:
        if proc.poll() is not None:
            break
        time.sleep(1)
    if proc.poll() is None:
        proc.terminate()
        proc.wait(timeout=5)
    return pcap_file if Path(pcap_file).exists() else None

def authorized_deauth_test(iface: str, target_bssid: str, client_mac: Optional[str], count: int, duration: int, dry_run: bool = False):
    if count > MAX_DEAUTH_COUNT:
        logger.error(f"Deauth count exceeds safety limit (max {MAX_DEAUTH_COUNT}).")
        return
    if duration > MAX_DEAUTH_DURATION:
        logger.error(f"Deauth duration exceeds safety limit (max {MAX_DEAUTH_DURATION}s).")
        return
    cmd = ["aireplay-ng", "--deauth", str(count)]
    if client_mac:
        cmd.extend(["-c", client_mac])
    cmd.extend(["-a", target_bssid, iface])
    if dry_run:
        logger.info(f"[DRY RUN] Would execute: {' '.join(cmd)}")
        return
    logger.warning(f"Initiating authorized deauth test: {target_bssid} | Count: {count} | Duration: {duration}s")
    proc = subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    proc_mgr.add(proc)
    time.sleep(duration)
    proc.terminate()
    proc.wait(timeout=5)

