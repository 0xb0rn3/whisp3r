def wireless_recon_workflow(args: argparse.Namespace) -> bool:
    adapters = detect_wireless_adapters()
    if not adapters:
        logger.error("No wireless adapters detected")
        return False
    print("\nAvailable adapters:")
    for i, a in enumerate(adapters):
        print(f"  {i+1}. {a.name} (MAC: {a.mac}, Monitor: {'Yes' if a.supports_monitor else 'No'})")
    iface_choice = int(input("Select adapter (number): ")) - 1
    if iface_choice < 0 or iface_choice >= len(adapters):
        logger.error("Invalid adapter selection")
        return False
    iface = adapters[iface_choice].name
    if not adapters[iface_choice].supports_monitor:
        logger.warning(f"{iface} may not support monitor mode")
    with monitor_mode_manager(iface, args.dry_run):
        duration = int(input("Capture duration (seconds, default 60): ") or "60")
        channel = input("Channel (optional, press Enter for all): ").strip()
        channel = int(channel) if channel.isdigit() else None
        out_prefix = f"whisp3r_capture_{int(time.time())}"
        pcap = run_airodump_capture(iface, out_prefix, duration, channel, args.dry_run)
        csv_path = f"{out_prefix}-01.csv"
        aps = parse_airodump_csv(csv_path)
        print(f"\nCaptured {len(aps)} access points:")
        for ap in aps:
            print(f"  [{ap.bssid}] {ap.essid} | Ch:{ap.channel} | {ap.encryption} | Signal:{ap.signal}dBm")
        if args.export and aps:
            export_results([asdict(a) for a in aps], f"aps_{int(time.time())}", args.export)
        if pcap:
            logger.info(f"PCAP saved: {pcap}")
            if input("Verify handshake? (y/n): ").lower() == 'y':
                verify_handshake(pcap, args.dry_run)
    return True

def network_recon_workflow(args: argparse.Namespace) -> bool:
    iface = args.interface or input("Interface for scanning: ").strip()
    subnet = input("Target subnet (default 192.168.1.0/24): ").strip() or "192.168.1.0/24"
    hosts = scan_network(iface, subnet, args.dry_run)
    print(f"\nDiscovered {len(hosts)} hosts:")
    for h in hosts:
        print(f"  {h.ip} ({h.hostname or 'N/A'}) | MAC: {h.mac or 'N/A'}")
    if input("Perform service scan on hosts? (y/n): ").lower() == 'y':
        for h in hosts:
            enhanced = service_scan(h.ip, iface, args.dry_run)
            h.open_tcp_ports = enhanced.open_tcp_ports
            h.open_udp_ports = enhanced.open_udp_ports
            h.service_banners = enhanced.service_banners
            h.os_detection = enhanced.os_detection
            print(f"\n{h.ip} services:")
            for port, banner in h.service_banners.items():
                print(f"  Port {port}: {banner}")
    if args.export and hosts:
        export_results([asdict(h) for h in hosts], f"hosts_{int(time.time())}", args.export)
    return True

