def payload_generation_workflow(args: argparse.Namespace) -> bool:
    if not args.authorized:
        logger.error("Payload generation requires explicit --authorized flag")
        return False
    cve_db = init_cve_database()
    print(f"\nAvailable CVEs with payload mappings:")
    cve_list = list(cve_db.keys())
    for i, cve in enumerate(cve_list):
        print(f"  {i+1}. {cve}")
    cve_choice = int(input("Select CVE (number): ")) - 1
    if cve_choice < 0 or cve_choice >= len(cve_list):
