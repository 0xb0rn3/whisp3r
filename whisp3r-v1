def scan_network(interface: str, subnet: str, dry_run: bool = False) -> List[Host]:
    hosts = []
    xml_file = OUTPUT_DIR / f"nmap_scan_{int(time.time())}.xml"
    xml_file.parent.mkdir(parents=True, exist_ok=True)
    cmd = ["nmap", "-sn", "-oX", str(xml_file), subnet, "-e", interface]
    if dry_run:
        logger.info(f"[DRY RUN] Would execute: {' '.join(cmd)}")
        return hosts
    logger.info(f"Scanning {subnet} via {interface}...")
    run_cmd(cmd, timeout=300, dry_run=dry_run)
    if xml_file.exists():
        import xml.etree.ElementTree as ET
        tree = ET.parse(xml_file)
        root = tree.getroot()
        for host in root.findall('.//host'):
            addr = host.find('.//address[@addrtype="ipv4"]')
            if addr is not None:
                ip = addr.get('addr')
                mac_elem = host.find('.//address[@addrtype="mac"]')
                mac = mac_elem.get('addr') if mac_elem is not None else None
                hostname_elem = host.find('.//hostname')
                hostname = hostname_elem.get('name') if hostname_elem is not None else None
                hosts.append(Host(ip=ip, mac=mac, hostname=hostname))
    return hosts

def service_scan(host_ip: str, interface: str, dry_run: bool = False) -> Host:
    host = Host(ip=host_ip)
    xml_file = OUTPUT_DIR / f"nmap_service_{host_ip.replace('.','_')}_{int(time.time())}.xml"
    cmd = ["nmap", "-sV", "-sC", "-oX", str(xml_file), "-Pn", host_ip, "-e", interface]
    if dry_run:
        logger.info(f"[DRY RUN] Would execute: {' '.join(cmd)}")
        return host
    logger.info(f"Service scanning {host_ip}...")
    run_cmd(cmd, timeout=600, dry_run=dry_run)
    if xml_file.exists():
        import xml.etree.ElementTree as ET
        tree = ET.parse(xml_file)
        root = tree.getroot()
        host_elem = root.find('.//host')
        if host_elem is not None:
            os_elem = host_elem.find('.//osmatch')
            if os_elem is not None:
                host.os_detection = os_elem.get('name')
            for port in host_elem.findall('.//port'):
                port_id = port.get('portid')
                protocol = port.get('protocol')
                state = port.find('state')
                if state is not None and state.get('state') == 'open':
                    port_num = int(port_id)
                    service = port.find('service')
                    if service is not None:
                        banner = service.get('product', '') + ' ' + service.get('version', '')
                        host.service_banners[port_num] = banner.strip()
                    if protocol == 'tcp':
                        host.open_tcp_ports.append(port_num)
                    elif protocol == 'udp':
                        host.open_udp_ports.append(port_num)
    return host

