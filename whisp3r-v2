class ProcessManager:
    def __init__(self):
        self.pids = []
        self.lock = threading.Lock()
    def add(self, proc):
        with self.lock:
            self.pids.append(proc)
    def cleanup(self):
        with self.lock:
            for proc in self.pids:
                if proc.poll() is None:
                    try:
                        proc.terminate()
                        proc.wait(timeout=5)
                    except: pass
            self.pids.clear()

class AuditLogger:
    def __init__(self, log_path=LOG_PATH):
        self.log_path = Path(log_path)
        self.log_path.parent.mkdir(parents=True, exist_ok=True)
        self.lock = threading.Lock()
    def log(self, action, target, params, result, authorized=False):
        entry = AuditEntry(datetime.now().isoformat(), action, target, params, result, "whisp3r_operator", authorized)
